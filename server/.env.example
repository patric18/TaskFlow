# Server — copy to server/.env
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
LOG_LEVEL=debug

# Database (matches docker-compose.yml defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskflow
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/taskflow_test

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379

# JWT — change these secrets before production
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars!!
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe (Step 9) — optional in development; use dev billing without keys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx

# Dev-only: activate Pro without Stripe (never use in production)
# BILLING_DEV_MODE=true

# Resend (Step 3)
RESEND_API_KEY=re_xxx
EMAIL_FROM=TaskFlow <noreply@taskflow.app>

# Cloudinary (Step 8+)
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx
